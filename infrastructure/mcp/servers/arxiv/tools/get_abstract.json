{
    "name": "get_abstract",
    "description": "获取单篇 ArXiv 论文的完整信息（标题、作者、摘要、分类、发布日期）。比 search_papers 更详细，适合深度了解某篇论文。",
    "inputSchema": {
        "type": "object",
        "properties": {
            "paper_id": {
                "type": "string",
                "description": "ArXiv 论文 ID，如 2401.12345"
            }
        },
        "required": ["paper_id"]
    }
}
