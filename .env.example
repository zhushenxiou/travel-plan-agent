# ===== LLM 配置 =====
# 通义千问 / OpenAI 兼容接口
CLAW_API_KEY=your-api-key-here
CLAW_MODEL=qwen3.5-122b-a10b
CLAW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 第三方服务密钥 =====
# 高德地图（Web 服务 API）
AMAP_WEBSERVICE_KEY=your-amap-webservice-key

# 高德地图（JS API）
AMAP_JS_API_KEY=your-amap-js-api-key

# 飞猪旅行 API
FLYAI_API_KEY=your-flyai-api-key

# ===== 运行参数（可选，均有默认值）=====
