# ===== LLM 配置 =====
# 通义千问 / OpenAI 兼容接口
CLAW_API_KEY=your-api-key-here
CLAW_MODEL=qwen3.5-122b-a10b
CLAW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 第三方服务密钥 =====
# 高德地图 Web 服务 Key（必填）
#   用途：后端调用高德 REST API（地理编码、天气、POI 搜索、路线规划）
#   申请：高德控制台 → 应用管理 → 添加 Key → 平台类型选「Web 服务」
#   注意：不能和 JS API Key 混用，否则会报 USERKEY_PLAT_NOMATCH（infocode=10009）
AMAP_WEBSERVICE_KEY=your-amap-webservice-key

# 高德地图 JS API Key（可选，前端地图展示用）
#   用途：浏览器端加载高德 JS API 时的鉴权 Key
#   申请：高德控制台 → 应用管理 → 添加 Key → 平台类型选「Web 端」
#   项目当前前端使用 Leaflet + 高德瓦片，暂未依赖此 Key，预留给将来切换高德原生 JS API
AMAP_JS_API_KEY=your-amap-js-api-key

# 高德 JS API 安全密钥（可选，配合 AMAP_JS_API_KEY 使用）
#   用途：高德 JS API v2 鉴权需要同时传 key + securityJsCode，防止 Key 被盗用
#   获取：在高德控制台「Web 端」Key 详情页中查看「安全密钥」
#   前端通过 VITE_AMAP_SECURITY_KEY 注入，只有 VITE_ 前缀的变量才会被 Vite 打包到前端
VITE_AMAP_SECURITY_KEY=your-amap-security-key

# 飞猪旅行 API（可选，用于机票/酒店/火车票查询）
FLYAI_API_KEY=your-flyai-api-key

# ===== 运行参数（可选，均有默认值）=====
# CLAW_LOG_LEVEL=INFO
# CLAW_MAX_ITERATIONS=15
# CLAW_RATE_LIMIT_RPM=60
# CLAW_DATABASE_PATH=data/claw.db
