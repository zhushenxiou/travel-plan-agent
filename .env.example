# ===== LLM 配置（必填）=====
CLAW_API_KEY=your-api-key-here
CLAW_MODEL=qwen3.6-flash
CLAW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 高德地图（必填，用于地理编码）=====
AMAP_WEBSERVICE_KEY=your-amap-webservice-key

# ===== 飞猪旅行（可选，用于机票/酒店查询）=====
FLYAI_API_KEY=

# ===== 高德 JS API（可选，前端地图展示）=====
AMAP_JS_API_KEY=

# ===== 日志配置 =====
# CLAW_LOG_LEVEL=DEBUG
# CLAW_LOG_TO_CONSOLE=true
# CLAW_LOG_TO_FILE=true

# ===== 数据库 =====
# CLAW_DATABASE_PATH=data/claw.db

# ===== 限流 =====
# CLAW_RATE_LIMIT_RPM=60

# ===== 监控 =====
# CLAW_METRICS_ENABLED=true
# CLAW_METRICS_PORT=9090

# ===== Redis（可选）=====
# CLAW_REDIS_URL=redis://localhost:6379/0

# ===== 前端 =====
VITE_PUBLIC_URL=http://localhost:5173
VITE_AMAP_KEY=
